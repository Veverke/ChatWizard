    "menus": {
      "view/title": [
        {
          "command": "chatwizard.filterSessions",
          "when": "view == chatwizardSessions",
          "group": "navigation@0"
        },
        {
          "command": "chatwizard.configureSortOrder",
          "when": "view == chatwizardSessions",
          "group": "navigation@0"
        },
        {
          "command": "chatwizard.enableSessionGrouping",
          "when": "view == chatwizardSessions && chatwizard.sessionGrouped == false",
          "group": "navigation@0"
        },
        {
          "command": "chatwizard.disableSessionGrouping",
          "when": "view == chatwizardSessions && chatwizard.sessionGrouped != false",
          "group": "navigation@0"
        },
        {
          "command": "chatwizard.sortByDate",
          "when": "view == chatwizardSessions && chatwizard.sortKey != 'date'",
          "group": "navigation@1"
        },
        {
          "command": "chatwizard.sortByDate.asc",
          "when": "view == chatwizardSessions && chatwizard.sortKey == 'date' && chatwizard.sortDir == 'asc'",
          "group": "navigation@1"
        },
        {
          "command": "chatwizard.sortByDate.desc",
          "when": "view == chatwizardSessions && chatwizard.sortKey == 'date' && chatwizard.sortDir == 'desc'",
          "group": "navigation@1"
        },
        {
