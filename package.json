          "group": "navigation@2"
        },
        {
          "command": "chatwizard.sortByWorkspace.desc",
          "when": "view == chatwizardSessions && chatwizard.sortKey == 'workspace' && chatwizard.sortDir == 'desc'",
          "group": "navigation@2"
        },
        {
          "command": "chatwizard.sortByLength",
