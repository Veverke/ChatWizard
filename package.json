{
  "name": "chatwizard",
  "displayName": "Chat Wizard",
  "description": "Browse, search, and analyze AI coding-assistant conversation history from GitHub Copilot, Claude Code, Cline, Roo Code, Cursor, Windsurf, Aider, and Google Antigravity (prompts only). Chat history viewer, prompt library, code block browser, token analytics, and timeline — all in one extension.",
  "version": "1.3.0",
  "publisher": "Veverke",
  "icon": "images/icon.png",
  "license": "SEE LICENSE IN LICENSE",
  "keywords": [
    "copilot",
    "claude",
    "cline",
    "roo",
    "roocode",
    "windsurf",
    "cursor",
    "aider",
    "codeium",
    "ai",
    "chat",
    "history",
    "search",
    "analytics",
    "prompt-library",
    "code-blocks",
    "timeline",
    "chat-history",
    "conversation-history",
    "history-viewer",
    "token-usage",
    "ai-productivity",
    "llm",
    "vscode",
    "ide"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/veverke/chatwizard.git"
  },
  "bugs": {
    "url": "https://github.com/veverke/chatwizard/issues"
  },
  "homepage": "https://github.com/veverke/chatwizard#readme",
  "galleryBanner": {
    "color": "#16324f",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Machine Learning",
    "Visualization"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "chatwizard",
          "title": "Chat Wizard",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "chatwizard": [
        {
          "id": "chatwizardSessions",
          "name": "Sessions"
        },
        {
          "id": "chatwizardPromptLibrary",
          "name": "Prompt Library",
          "type": "webview"
        },
        {
          "id": "chatwizardCodeBlocks",
          "name": "Code Blocks"
        },
        {
          "id": "chatwizardAnalytics",
          "name": "Analytics",
          "type": "webview"
        },
        {
          "id": "chatwizardModelUsage",
          "name": "Model Usage",
          "type": "webview"
        },
        {
          "id": "chatwizardTimeline",
          "name": "Timeline",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "chatwizard.openSession",
        "title": "Open Session",
        "category": "Chat Wizard"
      },
      {
