      "view/item/context": [
        {
          "command": "chatwizard.pinSession",
          "when": "viewItem == session",
          "group": "1_pin@1"
        },
        {
          "command": "chatwizard.unpinSession",
          "when": "viewItem == session.pinned",
          "group": "1_pin@1"
        },
        {
          "command": "chatwizard.exportSession",
          "when": "viewItem == session || viewItem == session.pinned",
          "group": "2_export@1"
        },
        {
          "command": "chatwizard.exportFromTreeSelection",
          "when": "viewItem == session || viewItem == session.pinned",
          "group": "2_export@2"
        },
        {
          "command": "chatwizard.pinSession",
          "when": "viewItem == session",
          "group": "inline@1"
        },
        {
          "command": "chatwizard.unpinSession",
          "when": "viewItem == session.pinned",
          "group": "inline@1"
        },
        {
          "command": "chatwizard.exportSession",
          "when": "viewItem == session || viewItem == session.pinned",
          "group": "inline@2"
        }
      ]
    },
    "configuration": {
      "title": "Chat Wizard",
      "properties": {
        "chatwizard.userMessageColor": {
          "type": "string",
          "default": "#007acc",
          "description": "Accent color for user message border and label (hex, e.g. #ff6600, or CSS color name).",
          "format": "color-hex"
        },
        "chatwizard.tooltipLabelColor": {
          "type": "string",
          "default": "",
          "description": "Color for field label text in session hover tooltips (hex or CSS name). Leave blank for default theme color.",
          "format": "color-hex"
        },
        "chatwizard.codeBlockHighlightColor": {
          "type": "string",
          "default": "#EA5C00",
          "description": "Box-shadow color applied to code blocks when opening a session from the Code Blocks view. Leave blank to disable highlighting.",
          "format": "color-hex"
        },
        "chatwizard.scrollToFirstCodeBlock": {
          "type": "boolean",
          "default": true,
          "description": "When opening a session from the Code Blocks view, automatically scroll to the first code block."
        },
        "chatwizard.claudeProjectsPath": {
          "type": "string",
          "default": "",
          "description": "Custom path to the Claude Code projects directory (where .jsonl session files are stored). Leave empty to use the default: ~/.claude/projects"
        },
        "chatwizard.copilotStoragePath": {
          "type": "string",
          "default": "",
          "description": "Custom path to the GitHub Copilot Chat workspace storage directory. Leave empty to use the platform default (%APPDATA%/Code/User/workspaceStorage on Windows)."
        },
        "chatwizard.enableTelemetry": {
          "type": "boolean",
          "default": false,
          "description": "Enable local usage telemetry. Events are recorded to a local JSONL file in the extension's global storage directory. No data ever leaves your machine."
        },
        "chatwizard.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable the Chat Wizard extension. When false, no sessions are indexed and all file watching is skipped."
        },
        "chatwizard.indexClaude": {
          "type": "boolean",
          "default": true,
          "description": "Index Claude Code chat sessions from ~/.claude/projects/ (or the configured custom path)."
        },
        "chatwizard.indexCopilot": {
          "type": "boolean",
          "default": true,
          "description": "Index GitHub Copilot Chat sessions from VS Code workspace storage."
        },
        "chatwizard.oldestSessionDate": {
          "type": "string",
          "default": "",
          "pattern": "^(\\d{4}-\\d{2}-\\d{2})?$",
          "patternErrorMessage": "Use YYYY-MM-DD format, e.g. 2025-01-01, or leave empty for no date limit.",
          "description": "Only load sessions created on or after this date (YYYY-MM-DD). Leave empty to load all sessions regardless of date."
        },
        "chatwizard.maxSessions": {
          "type": "integer",
          "default": 0,
          "minimum": 0,
          "description": "Maximum number of sessions to load. When set to a value greater than 0, only the N most recently updated sessions are kept after all other filters are applied. Set to 0 for no limit."
        },
        "chatwizard.maxLineLengthChars": {
          "type": "integer",
          "default": 1000000,
          "minimum": 10000,
          "description": "Maximum character length of a single JSONL line when parsing Claude sessions. Lines exceeding this limit are shown as a notice placeholder in the session viewer instead of being silently dropped. Increase this if large messages are being truncated; lower it to reduce memory usage when indexing."
        },
        "chatwizard.indexCline": {
          "type": "boolean",
          "default": true,
          "description": "Index Cline (saoudrizwan.claude-dev) task history."
        },
        "chatwizard.clineStoragePath": {
          "type": "string",
          "default": "",
          "description": "Override the Cline globalStorage path. Leave empty to use the default OS location (%APPDATA%/Code/User/globalStorage/saoudrizwan.claude-dev/tasks on Windows)."
        },
        "chatwizard.indexRooCode": {
          "type": "boolean",
          "default": true,
          "description": "Index Roo Code (rooveterinaryinc.roo-cline) task history."
        },
        "chatwizard.rooCodeStoragePath": {
          "type": "string",
          "default": "",
          "description": "Override the Roo Code globalStorage path. Leave empty to use the default OS location (%APPDATA%/Code/User/globalStorage/rooveterinaryinc.roo-cline/tasks on Windows)."
        },
        "chatwizard.indexCursor": {
          "type": "boolean",
          "default": true,
          "description": "Index Cursor chat sessions from the Cursor workspaceStorage directory."
        },
        "chatwizard.cursorStoragePath": {
          "type": "string",
          "default": "",
          "description": "Override the Cursor workspaceStorage path. Leave empty to use the default OS location (%APPDATA%/Cursor/User/workspaceStorage on Windows)."
        },
        "chatwizard.indexWindsurf": {
          "type": "boolean",
          "default": true,
          "description": "Index Windsurf (Codeium) Cascade chat sessions from the Windsurf workspaceStorage directory."
        },
        "chatwizard.windsurfStoragePath": {
          "type": "string",
          "default": "",
          "description": "Override the Windsurf workspaceStorage path. Leave empty to use the default OS location (%APPDATA%/Windsurf/User/workspaceStorage on Windows)."
        },
        "chatwizard.indexAider": {
          "type": "boolean",
          "default": true,
          "description": "Index Aider chat history files (.aider.chat.history.md) found in VS Code workspace folders and any configured aiderSearchRoots."
        },
        "chatwizard.aiderSearchRoots": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Additional root directories to search for .aider.chat.history.md files (up to aiderSearchDepth levels deep)."
        },
        "chatwizard.aiderSearchDepth": {
          "type": "integer",
          "default": 3,
          "minimum": 1,
          "maximum": 5,
          "description": "Maximum directory depth to recurse when searching for .aider.chat.history.md files (default: 3, max: 5)."
        },
        "chatwizard.indexAntigravity": {
          "type": "boolean",
          "default": true,
          "description": "Index Google Antigravity agent conversation sessions from the ~/.gemini/antigravity/brain directory."
        },
        "chatwizard.antigravityBrainPath": {
          "type": "string",
          "default": "",
          "description": "Override the Google Antigravity brain directory path. Leave empty to use the default OS location (~/.gemini/antigravity/brain)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run rebuild:native && npm run bundle",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vscode-test",
    "rebuild:native": "node scripts/rebuild-native.js",
    "bundle": "esbuild src/extension.ts --bundle --platform=node --external:vscode --external:better-sqlite3 --outfile=dist/extension.js",
    "bundle:watch": "esbuild src/extension.ts --bundle --platform=node --external:vscode --external:better-sqlite3 --outfile=dist/extension.js --sourcemap --watch",
    "package:vsix:win32-x64": "npm run rebuild:native && npm run bundle && npx @vscode/vsce package --target win32-x64 --out chatwizard-win32-x64.vsix",
    "package:vsix:linux-x64": "npm run rebuild:native && npm run bundle && npx @vscode/vsce package --target linux-x64 --out chatwizard-linux-x64.vsix",
    "package:vsix:darwin-arm64": "npm run rebuild:native && npm run bundle && npx @vscode/vsce package --target darwin-arm64 --out chatwizard-darwin-arm64.vsix"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.8",
    "@types/mocha": "^10.0.6",
    "@types/node": "18.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/test-cli": "^0.0.6",
    "@vscode/test-electron": "^2.3.8",
    "esbuild": "^0.27.4",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3"
  }
}
